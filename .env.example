# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_API_BASE_URL: The URL of the backend API service (e.g. Django, Express).
# Vite requires public frontend environment variables to be prefixed with 'VITE_'.
VITE_API_BASE_URL="https://zeeshanbalti.pythonanywhere.com/api"

